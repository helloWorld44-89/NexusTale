# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Frontend build artifacts (rebuilt inside container) ───────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/

# ── Go build artifacts ────────────────────────────────────────────────────────
backend/bin/
backend/tmp/
backend/vendor/
backend/*.exe
backend/*.test
backend/*.out

# ── Environment & secrets (injected at runtime) ───────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Local data volumes ────────────────────────────────────────────────────────
backend/data/
data/

# ── Docs (not needed in app images) ──────────────────────────────────────────
docs/
branding/
*.md
!backend/README.md

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Logs & test output ────────────────────────────────────────────────────────
*.log
coverage.out
coverage.html
test-results/

# ── CI ────────────────────────────────────────────────────────────────────────
.github/

# ── Host tooling ─────────────────────────────────────────────────────────────
Makefile
