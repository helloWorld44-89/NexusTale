# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Frontend dependencies (rebuilt inside container) ─────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/

# ── Go build artifacts ────────────────────────────────────────────────────────
backend/bin/
backend/tmp/
backend/vendor/
backend/*.exe
backend/*.test
backend/*.out

# ── Environment & secrets (injected at runtime via k8s secrets / compose) ────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Local data volumes (never baked into image) ───────────────────────────────
backend/data/
postgres-data/
redis-data/
minio-data/

# ── Docs & infra (not needed in app images) ──────────────────────────────────
docs/
infra/
*.md
!backend/README.md

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Logs & test output ────────────────────────────────────────────────────────
*.log
coverage.out
coverage.html
test-results/

# ── CI ────────────────────────────────────────────────────────────────────────
.github/

# ── Makefile (host tooling only) ─────────────────────────────────────────────
Makefile
