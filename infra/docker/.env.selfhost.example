# NexusTale self-host config.
# Copy this file to .env in the same directory, fill in the required
# section, then:
#   docker compose -f docker-compose.selfhost.yml --env-file .env up -d

# ── Required ──────────────────────────────────────────────────────────────
# Generate each of these with: openssl rand -hex 32
# There are no defaults for these on purpose — the API will run with weak
# secrets if you leave them blank, so don't skip this.

NEXUSTALE_JWT_SECRET=
NEXUSTALE_ENCRYPTION_KEY=
NEXUSTALE_DB_PASSWORD=
NEXUSTALE_MINIO_ACCESSKEY=
NEXUSTALE_MINIO_SECRETKEY=

# ── Optional ──────────────────────────────────────────────────────────────

# Local port NexusTale is reachable on. Put your own reverse proxy
# (Nginx Proxy Manager, Caddy, Traefik, Cloudflare Tunnel, ...) in front of
# this if you want TLS / a public domain — NexusTale doesn't bundle either.
NEXUSTALE_PORT=8080

# Image tag to run. "latest" tracks the newest tagged release; pin to a
# specific version (e.g. v0.3.0) for reproducible, deliberate upgrades.
NEXUSTALE_VERSION=latest

# Registration is open by default so you can create your own account.
# Set to false once your instance is set up, if you don't want randoms
# signing up (only matters if you've exposed this beyond your LAN).
NEXUSTALE_REGISTRATIONOPEN=true

# Once you've put a domain + reverse proxy in front of NexusTale, set both
# of these to lock the API down properly:
#   NEXUSTALE_SERVER_MODE=release
#   NEXUSTALE_ALLOWEDORIGIN=https://your-domain.example
# Leave unset for local/LAN-only use — the API defaults to debug mode with
# permissive CORS so a fresh install never crash-loops on startup.
# NEXUSTALE_SERVER_MODE=release
# NEXUSTALE_ALLOWEDORIGIN=https://your-domain.example

# Only needed if you run Ollama on the host machine (not in Docker) and it
# doesn't resolve at http://host.docker.internal:11434 for some reason.
# NEXUSTALE_OLLAMA_URL=http://host.docker.internal:11434
