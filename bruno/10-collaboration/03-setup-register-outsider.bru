meta {
  name: setup-register-outsider
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "outsider@test.com",
    "display_name": "Outsider User",
    "password": "Test1234!"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("collabOutsiderToken", res.body.tokens.access_token);
  }
}

tests {
  test("status is 201", function() {
    expect(res.status).to.equal(201);
  });
}
