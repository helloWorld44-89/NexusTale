meta {
  name: logout
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/auth/logout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns logged out message", function() {
    expect(res.body.message).to.equal("logged out");
  });
}
