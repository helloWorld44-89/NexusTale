meta {
  name: delete-lore
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/wiki/entities/{{loreId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns deleted message", function() {
    expect(res.body.message).to.equal("entity deleted");
  });
}
