meta {
  name: delete-act
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/acts/{{actId2}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns success message", function() {
    expect(res.body).to.have.property("message");
  });
}
