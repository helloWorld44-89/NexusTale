meta {
  name: refresh-reuse-old
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "expired-or-already-rotated-token"
  }
}

tests {
  test("status is 401", function() {
    expect(res.status).to.equal(401);
  });

  test("rejects reused/invalid token", function() {
    expect(res.body.message).to.equal("unauthorized");
  });
}
