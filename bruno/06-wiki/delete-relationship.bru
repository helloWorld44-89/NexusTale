meta {
  name: delete-relationship
  type: http
  seq: 22
}

delete {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/wiki/relationships/{{relationshipId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns deleted message", function() {
    expect(res.body.message).to.equal("relationship deleted");
  });
}
